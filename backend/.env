# OpenAI API Configuration
OPENAI_API_KEY=

# Database Configuration (Auto-injected on Render)
# For local development, replace this with your local PostgreSQL URL
DATABASE_URL=

# Tesseract OCR Configuration (Linux/Docker Paths)
TESSERACT_CMD=/usr/bin/tesseract
TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata
